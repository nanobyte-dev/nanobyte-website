<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: transparent;
            color: #ccc;
            margin: 0;
            padding: 20px;
        }

        .videos-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .video-card {
            background: #2d2842;
            border-radius: 8px;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .video-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
        }

        .video-thumbnail {
            width: 100%;
            aspect-ratio: 16 / 9;
            object-fit: cover;
            display: block;
            background: #1e1a2d;
        }

        .video-info {
            padding: 15px;
        }

        .video-title {
            color: #F0A9B8;
            font-size: 1em;
            margin-bottom: 8px;
            line-height: 1.4;
            font-weight: 500;
        }

        .video-date {
            color: #999;
            font-size: 0.85em;
        }

        .dev-banner {
            text-align: center;
            padding: 8px;
            background: rgba(240, 169, 184, 0.1);
            border: 1px dashed #F0A9B8;
            border-radius: 6px;
            margin-bottom: 20px;
            font-size: 0.85em;
            color: #F0A9B8;
        }

        @supports not (aspect-ratio: 16 / 9) {
            .video-thumbnail {
                height: 157px;
            }
        }
    </style>
</head>
<body>
    <div class="dev-banner">Dev mode — mock video data</div>
    <div class="videos-container">
        <a href="https://www.youtube.com/@nanobyte-dev" class="video-card" target="_blank" rel="noopener noreferrer">
            <img src="https://i.ytimg.com/vi/9t-SPC7Gs60/hqdefault.jpg" alt="Making an OS (x86) - Ep 22 - The USB boot process" class="video-thumbnail" loading="lazy">
            <div class="video-info">
                <div class="video-title">Making an OS (x86) - Ep 22 - The USB boot process</div>
                <div class="video-date">Mar 15, 2026</div>
            </div>
        </a>
        <a href="https://www.youtube.com/@nanobyte-dev" class="video-card" target="_blank" rel="noopener noreferrer">
            <img src="https://i.ytimg.com/vi/MwPjvJ9ulSc/hqdefault.jpg" alt="Memory management techniques - virtual memory explained" class="video-thumbnail" loading="lazy">
            <div class="video-info">
                <div class="video-title">Memory management techniques - virtual memory explained</div>
                <div class="video-date">Feb 28, 2026</div>
            </div>
        </a>
        <a href="https://www.youtube.com/@nanobyte-dev" class="video-card" target="_blank" rel="noopener noreferrer">
            <img src="https://i.ytimg.com/vi/mpIFag8zSWo/hqdefault.jpg" alt="Live: Solving libguestfs problems, stupid ELF" class="video-thumbnail" loading="lazy">
            <div class="video-info">
                <div class="video-title">Live: Solving libguestfs problems, stupid ELF</div>
                <div class="video-date">Feb 10, 2026</div>
            </div>
        </a>
        <a href="https://www.youtube.com/@nanobyte-dev" class="video-card" target="_blank" rel="noopener noreferrer">
            <img src="https://i.ytimg.com/vi/Dp28oDGBa8k/hqdefault.jpg" alt="Is ChatGPT replacing our jobs?" class="video-thumbnail" loading="lazy">
            <div class="video-info">
                <div class="video-title">Is ChatGPT replacing our jobs?</div>
                <div class="video-date">Jan 22, 2026</div>
            </div>
        </a>
        <a href="https://www.youtube.com/@nanobyte-dev" class="video-card" target="_blank" rel="noopener noreferrer">
            <img src="https://i.ytimg.com/vi/LnzuMJLZRnE/hqdefault.jpg" alt="Live: Working on C++ implementation of FAT" class="video-thumbnail" loading="lazy">
            <div class="video-info">
                <div class="video-title">Live: Working on C++ implementation of FAT</div>
                <div class="video-date">Jan 5, 2026</div>
            </div>
        </a>
        <a href="https://www.youtube.com/@nanobyte-dev" class="video-card" target="_blank" rel="noopener noreferrer">
            <img src="https://i.ytimg.com/vi/HANCzGMD0CE/hqdefault.jpg" alt="Building an OS - 12: Memory management basics" class="video-thumbnail" loading="lazy">
            <div class="video-info">
                <div class="video-title">Building an OS - 12: Memory management basics</div>
                <div class="video-date">Dec 18, 2025</div>
            </div>
        </a>
    </div>
</body>
</html>
